}
.fundraiser-card-actions {
  display: flex;
  gap: .55rem;
  flex-wrap: wrap;
}
.fundraiser-card-band {
  height: 5px;
  background: linear-gradient(90deg, var(--gold-lt), var(--gold-dk));
}
.fundraiser-card-band--paused { background: var(--border); }
.btn-publish {
  padding: .55rem 1rem;
  border-radius: var(--r2);
  border: none;
  font-weight: 700;
  font-size: .84rem;
