}
.btn-publish--ready { background: #059669; color: #fff; cursor: pointer; }
.btn-publish--pause { background: #fef3c7; color: #92400e; cursor: pointer; }
.btn-publish--disabled { background: #e5e7eb; color: #9ca3af; cursor: not-allowed; }
.btn-delete-draft {
  padding: .55rem .85rem;
  border-radius: var(--r2);
