<file path="frontend/src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap');

/* ─── Design Tokens ─────────────────────────────────── */
:root {
  /* Surfaces */
  --bg:        #F6EDDA;
  --surface:   #EFE4CE;
  --surface-2: #E8DAC2;
  --surface-3: #DFD0B4;

  /* Dark */
  --dark:      #221508;
  --dark-2:    #3A2510;
  --dark-3:    #553820;

  /* Gold */
  --gold:      #C3A256;
  --gold-dk:   #A88844;
  --gold-lt:   #D4B870;
  --gold-pale: #F0E4C8;

  /* Text */
  --t1:        #1E1308;
  --t2:        #4A3820;
  --t3:        #7A6448;
  --t-cream:   #F2E4CE;
  --t-gold:    #D8B870;

  /* Borders */
  --border:    #D0BC98;
  --border-lt: #DDD0B8;

  /* Semantic colours */
  --green:     #4E6D38;
  --green-bg:  #EAF2E4;
  --orange:    #C87826;
  --orange-bg: #FEF3E5;
  --red:       #BF3535;
  --red-bg:    #FAECEC;

  /* Typography */
  --serif: 'Playfair Display', Georgia, serif;
  --sans:  'DM Sans', 'Avenir Next', system-ui, sans-serif;

  /* Radii */
  --r1: 8px;
  --r2: 12px;
  --r3: 18px;
  --r4: 24px;
  --rpill: 999px;

  /* Shadows */
  --sh1:       0 2px 8px  rgba(34,21,8,.07);
  --sh2:       0 6px 20px rgba(34,21,8,.11);
  --sh3:       0 16px 48px rgba(34,21,8,.15);
  --shadow-lg: 0 20px 60px rgba(34,21,8,.22);
}

/* ─── Reset ─────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: var(--sans);
  background: var(--bg);
  color: var(--t1);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  min-height: 100vh;
}
h1,h2,h3,h4 { font-family: var(--serif); margin: 0; line-height: 1.1; }
p  { margin: 0; }
a  { color: inherit; text-decoration: none; }
button { font-family: var(--sans); cursor: pointer; }
input, textarea, select { font-family: var(--sans); }

/* ─── Shared Navbar ──────────────────────────────────── */
.navbar {
  position: sticky;
  top: 0;
  z-index: 120;
  background: var(--bg);
  border-bottom: 1px solid var(--border-lt);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0 1.25rem;
  height: 56px;
  max-width: 1200px;
  margin: 0 auto;
}
.navbar-brand {
  font-family: var(--serif);
  font-size: 1.45rem;
  font-weight: 800;
  color: var(--dark);
  letter-spacing: -.01em;
  flex-shrink: 0;
}
.navbar-brand span { color: var(--gold); }
.navbar-links {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-left: auto;
}
.navbar-links a {
  font-size: .9rem;
  font-weight: 600;
  color: var(--t2);
  transition: color .15s;
}
.navbar-links a:hover { color: var(--t1); }
.navbar-links a.active { color: var(--dark); font-weight: 700; }
.navbar-end {
  display: flex;
  align-items: center;
  gap: .6rem;
  margin-left: auto;
}
.navbar-links + .navbar-end { margin-left: 0; }
.navbar-menu-btn {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--surface);
  color: var(--dark);
  cursor: pointer;
  transition: background .15s, border-color .15s;
}
.navbar-menu-btn:hover { background: var(--surface-2); }
.navbar--open .navbar-menu-btn {
  background: var(--dark);
  border-color: var(--dark);
  color: var(--t-cream);
}
.navbar-dropdown {
  max-height: 0;
  overflow: hidden;
  transition: max-height .3s cubic-bezier(.16,1,.3,1);
  border-top: 1px solid transparent;
}
.navbar-dropdown--open {
  max-height: 420px;
  border-top-color: var(--border-lt);
}
.navbar-dropdown-inner {
  padding: .65rem 1rem 1rem;
  display: flex;
  flex-direction: column;
  gap: .25rem;
}
.navbar-dropdown-link {
  display: flex;
  align-items: center;
  width: 100%;
  padding: .85rem 1rem;
  border-radius: var(--r2);
  font-size: .95rem;
  font-weight: 600;
  color: var(--t2);
  background: none;
  border: none;
  text-align: left;
  cursor: pointer;
  transition: background .15s, color .15s;
}
.navbar-dropdown-link:hover,
.navbar-dropdown-link.active {
  background: var(--surface);
  color: var(--dark);
}
.navbar-dropdown-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: .5rem;
  padding: .85rem 1rem;
  border-radius: var(--r3);
  font-weight: 700;
  font-size: .92rem;
  background: var(--gold);
  color: #fff;
  text-align: center;
}
.navbar-dropdown-logout { color: var(--red); }
.navbar-backdrop {
  position: fixed;
  inset: 0;
  z-index: 110;
  background: rgba(34,21,8,.25);
  border: none;
  cursor: pointer;
}

/* ─── Shared Buttons ─────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .4rem;
  border: none;
  border-radius: var(--rpill);
  font-family: var(--sans);
  font-weight: 700;
  font-size: .88rem;
  letter-spacing: .03em;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  padding: .7rem 1.2rem;
  transition: opacity .15s, transform .1s;
}
.btn:hover  { opacity: .88; }
.btn:active { transform: scale(.98); }
.btn-gold   { background: var(--gold);  color: #fff; }
.btn-dark   { background: var(--dark);  color: var(--t-cream); }
.btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--t2); }
.btn-outline-lt { background: transparent; border: 1.5px solid rgba(255,255,255,.35); color: rgba(255,255,255,.92); }
.btn-green  { background: #4E8C35; color: #fff; }
.btn-sm     { padding: .48rem .85rem; font-size: .8rem; }
.btn-lg     { padding: .85rem 1.6rem; font-size: .97rem; letter-spacing: .04em; }
.btn-full   { width: 100%; }

/* ─── Gold Title Pill ────────────────────────────────── */
.title-pill {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  background: var(--gold);
  color: #fff;
  border-radius: var(--rpill);
  padding: .52rem 1.15rem;
  font-family: var(--serif);
  font-size: .97rem;
  font-weight: 700;
}

/* ─── Cards ──────────────────────────────────────────── */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r4);
  padding: 1.2rem 1.3rem;
}

/* ─── Fields ─────────────────────────────────────────── */
.field {
  display: flex;
  flex-direction: column;
  gap: .3rem;
}
.field > label {
  font-size: .7rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 700;
  color: var(--t3);
}
.field input,
.field textarea,
.field select {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: var(--r3);
  background: #FFFDF6;
  padding: .78rem .9rem;
  font-size: .95rem;
  color: var(--t1);
  transition: border-color .15s;
  outline: none;
}
.field input:focus,
.field textarea:focus { border-color: var(--gold); }
.field input::placeholder,
.field textarea::placeholder { color: #B0A090; }

/* ─── Status Badges ──────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  border-radius: var(--rpill);
  padding: .22rem .62rem;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.badge-pending  { background: var(--orange-bg); color: var(--orange); }
.badge-paid     { background: var(--green-bg);  color: var(--green);  }
.badge-refunded { background: var(--red-bg);    color: var(--red);    }
.badge-live     { background: var(--green-bg);  color: var(--green);  }

/* ─── Tabs ───────────────────────────────────────────── */
.tab-bar {
  display: flex;
  background: var(--surface-2);
  border-radius: var(--r3);
  padding: .22rem;
  gap: .2rem;
}
.tab-bar button {
  flex: 1;
  border: none;
  background: transparent;
  border-radius: var(--r2);
  padding: .62rem .9rem;
  font-size: .88rem;
  font-weight: 700;
  color: var(--t2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .4rem;
  transition: background .15s, color .15s;
}
.tab-bar button.active {
  background: var(--gold);
  color: #fff;
}

/* ─── Step Indicator ─────────────────────────────────── */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}
.stepper-step {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .8rem; font-weight: 700;
  background: var(--surface-2);
  border: 1.5px solid var(--border);
  color: var(--t3);
}
.stepper-step.done   { background: var(--dark);  border-color: var(--dark); color: #fff; }
.stepper-step.active { background: var(--gold);  border-color: var(--gold); color: #fff; }
.stepper-line {
  height: 1.5px; width: 36px;
  background: var(--border);
}
.stepper-line.done { background: var(--dark); }

/* ─── Data Table ─────────────────────────────────────── */
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead tr {
  border-bottom: 1.5px solid var(--border);
}
.data-table th {
  text-align: left;
  padding: .75rem 1rem;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--t3);
}
.data-table td {
  padding: .85rem 1rem;
  font-size: .9rem;
  border-bottom: 1px solid var(--border-lt);
  color: var(--t1);
}
.data-table tbody tr:hover { background: rgba(195,162,86,.06); }

/* ─── OTP Boxes ──────────────────────────────────────── */
.otp-group {
  display: flex; gap: .42rem;
}
.otp-box {
  width: 48px; height: 52px;
  border: 1.5px solid var(--border);
  border-radius: var(--r2);
  background: #FFFDF6;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; font-weight: 700;
  color: var(--t2);
}

/* ─── Page Wrapper ───────────────────────────────────── */
.page { min-height: 100vh; display: flex; flex-direction: column; }

/* ─── Section Utility ────────────────────────────────── */
.section { padding: 0 2rem; }
.section-inner { max-width: 1160px; margin: 0 auto; }

/* ─── Checkout flow ──────────────────────────────────── */
.checkout-page {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 90% 55% at 50% -8%, rgba(195,162,86,.14), transparent 55%),
    var(--bg);
}
.checkout-main {
  max-width: 560px;
  margin: 0 auto;
  padding: 1.25rem 1rem calc(6.5rem + env(safe-area-inset-bottom, 0px));
}
.checkout-main--wide {
  max-width: 1020px;
  padding-bottom: 2rem;
}
.checkout-stepper {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 0;
  margin: 1.1rem 0 1.5rem;
}
.checkout-stepper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
  max-width: 100px;
}
.checkout-stepper-dot {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .82rem;
  font-weight: 700;
  background: transparent;
  border: 2px solid var(--border);
  color: var(--t3);
  z-index: 1;
}
.checkout-stepper-dot.active {
  background: var(--gold);
  border-color: var(--gold);
  color: #fff;
}
.checkout-stepper-dot.done {
  background: var(--dark);
  border-color: var(--dark);
  color: #fff;
}
.checkout-stepper-label {
  font-size: .68rem;
  font-weight: 600;
  color: var(--t3);
  margin-top: .4rem;
  text-transform: uppercase;
  letter-spacing: .04em;
}
.checkout-stepper-label.active { color: var(--dark); }
.checkout-stepper-line {
  position: absolute;
  top: 16px;
  left: calc(50% + 16px);
  width: calc(100% - 32px);
  height: 2px;
  background: var(--border);
  z-index: 0;
}
.checkout-stepper-line.done { background: var(--gold); }
.checkout-stepper-item:last-child .checkout-stepper-line { display: none; }
.checkout-title {
  font-family: var(--serif);
  font-size: clamp(1.55rem, 4.5vw, 2.2rem);
  margin-bottom: 1.25rem;
  line-height: 1.15;
}
.checkout-form { display: flex; flex-direction: column; gap: 1rem; }
.checkout-error {
  background: var(--red-bg);
  border: 1px solid var(--red);
  border-radius: var(--r2);
  padding: .75rem .9rem;
  color: var(--red);
  font-size: .88rem;
  margin-bottom: 1rem;
}
.checkout-summary {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r4);
  padding: 1.1rem 1.2rem;
}
.checkout-summary-label {
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 700;
  color: var(--t3);
  margin-bottom: .75rem;
}
.checkout-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: .75rem;
  padding: .6rem 0;
  border-bottom: 1px solid var(--border-lt);
  font-size: .92rem;
}
.checkout-row:last-of-type { border-bottom: none; }
.checkout-total {
  display: flex;
  justify-content: space-between;
  padding-top: .75rem;
  margin-top: .25rem;
  border-top: 2px solid var(--border-lt);
  font-weight: 800;
  font-size: 1rem;
}
.checkout-actions {
  display: flex;
  gap: .75rem;
  margin-top: .5rem;
}
.checkout-actions .btn { flex: 1; min-height: 48px; }
.checkout-actions-sticky {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: .85rem 1rem calc(.85rem + env(safe-area-inset-bottom, 0px));
  background: rgba(246,237,218,.94);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid var(--border-lt);
  display: none;
}
.checkout-actions-sticky .checkout-actions { margin-top: 0; }
.checkout-pay-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 1.5rem;
  align-items: start;
}
.checkout-pay-sidebar { position: sticky; top: 80px; }

/* ─── Customer / shop mobile ─────────────────────────── */
.shop-main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 1.25rem 1rem calc(5.5rem + env(safe-area-inset-bottom, 0px));
}
.shop-main--customer {
  padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.25rem, 5vw, 2rem) calc(5.5rem + env(safe-area-inset-bottom, 0px));
}
.mobile-slider-wrap { display: none; }
.desktop-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 1.5rem; }
.desktop-next { display: flex; justify-content: flex-end; margin-top: .5rem; }
.mobile-sticky-bar {
  display: none;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: .75rem 1rem calc(.75rem + env(safe-area-inset-bottom, 0px));
  background: rgba(246,237,218,.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid var(--border-lt);
}
.mobile-sticky-bar-inner {
  display: flex;
  align-items: center;
  gap: .75rem;
  max-width: 1100px;
  margin: 0 auto;
}
.mobile-sticky-summary {
  flex: 1;
  min-width: 0;
}
.mobile-sticky-summary strong {
  display: block;
  font-size: .95rem;
  color: var(--dark);
}
.mobile-sticky-summary span {
  font-size: .78rem;
  color: var(--t3);
}
.mobile-sticky-bar .btn { flex-shrink: 0; min-width: 120px; }
.product-slider {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding-bottom: .25rem;
}
.product-slider::-webkit-scrollbar { display: none; }
.product-slide { flex: 0 0 100%; scroll-snap-align: start; }
.product-dots {
  display: flex;
  justify-content: center;
  gap: .4rem;
  margin-top: .85rem;
}
.product-dot {
  height: 8px;
  border-radius: 4px;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all .2s;
  background: var(--border);
}
.product-dot.active { width: 18px; background: var(--gold); }
.product-dot:not(.active) { width: 8px; }
.qty-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  font-weight: 700;
  font-size: 1.2rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: none;
  font-family: var(--sans);
}
.qty-btn--minus {
  border: 1.5px solid var(--border);
  background: #fff;
  color: var(--t2);
}
.qty-btn--plus {
  background: var(--gold);
  color: #fff;
}
.qty-input {
  width: 3.25rem;
  min-width: 3.25rem;
  text-align: center;
  border: 1.5px solid var(--border);
  border-radius: var(--r2);
  padding: .5rem .25rem;
  font-weight: 700;
  font-size: 1rem;
  font-variant-numeric: tabular-nums;
  background: #FFFDF6;
  outline: none;
}
.product-qty-row {
  min-width: 9.5rem;
  flex-shrink: 0;
}
.product-card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: .75rem;
  min-height: 5rem;
}
.cart-pill-desktop {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r3);
  padding: .55rem 1rem;
  display: flex;
  align-items: center;
  gap: .5rem;
  font-weight: 700;
  font-size: .9rem;
  flex-shrink: 0;
  min-width: 200px;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.cart-pill-desktop--visible {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

/* ─── Vendor nav ─────────────────────────────────────── */
.vendor-nav {
  position: sticky;
  top: 0;
  z-index: 120;
  background: linear-gradient(135deg, #1a1006 0%, var(--dark) 55%, #2d1c0c 100%);
  border-bottom: 1px solid rgba(195,162,86,.15);
  box-shadow: 0 4px 20px rgba(34,21,8,.1);
}
.vendor-nav .navbar-brand { color: var(--t-cream); }
.vendor-nav .navbar-brand span { color: var(--gold-lt); }
.vendor-nav .navbar-menu-btn { color: var(--t-cream); border-color: rgba(255,255,255,.15); }
.vendor-nav-inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0 1.25rem;
  height: 56px;
  max-width: 1200px;
  margin: 0 auto;
}
.vendor-nav-tabs {
  display: flex;
  align-items: center;
  gap: .35rem;
  margin-left: auto;
  background: var(--surface-2);
  border-radius: var(--r3);
  padding: .2rem;
}
.vendor-nav-tabs {
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.1);
}
.vendor-nav-tabs a {
  padding: .5rem 1rem;
  border-radius: var(--r2);
  font-size: .85rem;
  font-weight: 700;
  color: rgba(242,228,206,.75);
  transition: background .15s, color .15s;
}
.vendor-nav-tabs a.active {
  background: rgba(255,255,255,.14);
  color: #fff;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
}
.vendor-nav-end {
  display: flex;
  align-items: center;
  gap: .5rem;
  margin-left: auto;
}
.vendor-nav-tabs + .vendor-nav-end { margin-left: 0; }
.vendor-nav-user {
  background: rgba(255,255,255,.08);
  color: var(--t-cream);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--rpill);
  padding: .45rem .9rem;
  font-size: .8rem;
  font-weight: 700;
  cursor: pointer;
  font-family: var(--sans);
  transition: background .15s;
}
.vendor-nav-user:hover { background: rgba(255,255,255,.12); }
.vendor-nav-greeting {
  font-size: .82rem;
  font-weight: 700;
  color: var(--t3);
  padding: .25rem 1rem .5rem;
  margin: 0;
}
.vendor-main {
  max-width: 960px;
  margin: 0 auto;
  padding: 1.25rem 1rem 3rem;
}
.vendor-cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.vendor-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .85rem;
}
.vendor-tab-bar {
  max-width: 440px;
  margin-bottom: 1.25rem;
}
.card-label {
  font-size: .7rem;
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 700;
  color: var(--t3);
  margin-bottom: .75rem;
}
.vendor-link-row {
  display: flex;
  flex-direction: column;
  gap: .65rem;
}
.vendor-link-input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: var(--r3);
  background: #FFFDF6;
  padding: .78rem .9rem;
  font-size: .88rem;
  color: var(--t3);
  outline: none;
}
.vendor-link-actions {
  display: flex;
  gap: .5rem;
}
.vendor-link-actions .btn { flex: 1; min-height: 44px; }
.vendor-stat-row {
  display: flex;
  justify-content: space-between;
  border-bottom: 1px solid var(--border-lt);
  padding-bottom: .45rem;
  margin-bottom: .45rem;
  font-size: .9rem;
}
.vendor-stat-row span { color: var(--t2); }

/* ─── Mobile ─────────────────────────────────────────── */
@media (max-width: 768px) {
  .hide-mobile { display: none !important; }
  .navbar-menu-btn { display: flex; }
  .navbar-inner { padding: 0 1rem; height: 52px; }
  .navbar-brand { font-size: 1.3rem; }

  .checkout-main--wide { padding-bottom: calc(6.5rem + env(safe-area-inset-bottom, 0px)); }
  .checkout-actions-sticky { display: block; }
  .checkout-actions--inline { display: none; }
  .checkout-pay-grid { grid-template-columns: 1fr; }
  .checkout-pay-sidebar { position: static; order: -1; }
  .title-pill { font-size: .85rem; padding: .45rem .9rem; max-width: 100%; }

  .mobile-slider-wrap { display: block; margin-bottom: 1rem; }
  .mobile-sticky-bar { display: block; }
  .desktop-grid,
  .desktop-next { display: none !important; }
  .cart-pill-desktop { display: none !important; }

  .vendor-cards-grid { grid-template-columns: 1fr; }
  .vendor-main { padding: 1rem 1rem 2.5rem; }
  .tab-bar button { font-size: .8rem; padding: .55rem .5rem; }

  .field input,
  .field textarea {
    font-size: 16px; /* prevents iOS zoom on focus */
    padding: .85rem .9rem;
  }
  .btn-lg { padding: .85rem 1.2rem; min-height: 48px; }
}

@media (min-width: 769px) {
  .checkout-actions-sticky { display: none !important; }
  .navbar-dropdown,
  .vendor-nav-dropdown { display: none !important; }
  .vendor-link-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
  }
  .vendor-link-input { flex: 1; min-width: 200px; }
  .vendor-link-actions { flex: 0 0 auto; width: auto; }
  .vendor-link-actions .btn { flex: 0 0 auto; }
}

/* ═══════════════════════════════════════════════════════
   MARKETING / LANDING — dark glass aesthetic
   ═══════════════════════════════════════════════════════ */

:root {
  --lp-bg:       #0B0C0F;
  --lp-fg:       #F2F3F5;
  --lp-muted:    #A7ABB3;
  --lp-border:   rgba(255,255,255,.1);
  --lp-glass:    rgba(11,12,15,.78);
  --lp-gold-grad: linear-gradient(135deg, #D4B870 0%, #C9A862 45%, #9A7535 100%);
}

/* ─── Glass Site Nav ─────────────────────────────────── */
.site-nav {
  position: fixed;
  top: 1.25rem;
  left: 1.25rem;
  right: 1.25rem;
  z-index: 200;
  border: 1px solid var(--lp-border);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  background: var(--lp-glass);
  border-radius: 16px;
  transition: background .3s, border-color .3s, box-shadow .3s;
}
.site-nav--scrolled {
  background: rgba(11,12,15,.92);
  border-color: rgba(255,255,255,.14);
  box-shadow: 0 8px 32px rgba(0,0,0,.35);
}
.site-nav-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 0 1.25rem;
  height: 56px;
  max-width: 1200px;
  margin: 0 auto;
}
.site-nav-brand {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--lp-fg);
  letter-spacing: -.01em;
  transition: color .2s;
}
.site-nav-brand span { color: var(--gold-lt); }
.site-nav-brand:hover { color: var(--gold-lt); }
.site-nav-links {
  display: flex;
  align-items: center;
  gap: 1.75rem;
  margin-left: auto;
}
.site-nav-link {
  background: none;
  border: none;
  font-family: var(--sans);
  font-size: .875rem;
  font-weight: 500;
  color: var(--lp-muted);
  cursor: pointer;
  transition: color .2s;
  padding: 0;
}
.site-nav-link:hover,
.site-nav-link.active { color: var(--lp-fg); }
.site-nav-actions {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-left: auto;
}
.site-nav-links + .site-nav-actions { margin-left: 0; }
.site-nav-cta {
  display: inline-flex;
  align-items: center;
  padding: .5rem 1.1rem;
  border-radius: 999px;
  font-size: .82rem;
  font-weight: 700;
  background: rgba(201,168,98,.15);
  border: 1px solid rgba(201,168,98,.35);
  color: var(--gold-lt);
  transition: background .2s, border-color .2s;
}
.site-nav-cta:hover {
  background: rgba(201,168,98,.28);
  border-color: rgba(201,168,98,.55);
}
.site-nav-menu-btn {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 10px;
  color: var(--lp-fg);
  cursor: pointer;
  transition: background .2s, border-color .2s;
}
.site-nav-menu-btn:hover { background: rgba(255,255,255,.12); }
.site-nav--open .site-nav-menu-btn {
  background: rgba(201,168,98,.2);
  border-color: rgba(201,168,98,.4);
}
.site-nav-dropdown {
  max-height: 0;
  overflow: hidden;
  transition: max-height .35s cubic-bezier(.16,1,.3,1);
  border-top: 1px solid transparent;
}
.site-nav-dropdown--open {
  max-height: 480px;
  border-top-color: rgba(255,255,255,.08);
}
.site-nav-dropdown-inner {
  padding: .5rem .75rem calc(.85rem + env(safe-area-inset-bottom, 0px));
  display: flex;
  flex-direction: column;
  gap: .15rem;
}
.site-nav-dropdown-link {
  display: flex;
  align-items: center;
  width: 100%;
  padding: .8rem 1rem;
  border-radius: 10px;
  font-size: .95rem;
  font-weight: 600;
  color: var(--lp-muted);
  background: none;
  border: none;
  text-align: left;
  cursor: pointer;
  transition: background .15s, color .15s;
}
.site-nav-dropdown-link:hover,
.site-nav-dropdown-link.active {
  background: rgba(255,255,255,.06);
  color: var(--lp-fg);
}
.site-nav-dropdown-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: .5rem;
  padding: .85rem 1rem;
  border-radius: 12px;
  font-weight: 700;
  font-size: .92rem;
  background: var(--gold);
  color: #fff;
}
.site-nav-backdrop {
  position: fixed;
  inset: 0;
  z-index: 195;
  background: rgba(0,0,0,.45);
  border: none;
  cursor: pointer;
}

/* ─── Landing page shell ─────────────────────────────── */
.landing-page {
  min-height: 100vh;
  background: var(--lp-bg);
  color: var(--lp-fg);
  overflow-x: hidden;
}

.landing-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 7rem 1.25rem 3rem;
  overflow: hidden;
}
.landing-hero-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  will-change: transform;
}
.landing-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, var(--lp-bg) 0%, rgba(11,12,15,.72) 45%, rgba(11,12,15,.35) 100%);
  pointer-events: none;
}
.landing-hero-content {
  position: relative;
  z-index: 2;
  max-width: 1120px;
  width: 100%;
  margin: 0 auto;
  text-align: center;
}
.landing-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .16em;
  color: var(--gold-lt);
  margin-bottom: 1.25rem;
}
.landing-eyebrow-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--gold);
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.85); }
}
.landing-headline {
  font-family: var(--serif);
  font-size: clamp(2.75rem, 7vw, 5rem);
  font-weight: 500;
  line-height: 1.05;
  margin-bottom: 1.25rem;
  letter-spacing: -.02em;
}
.landing-headline em {
  font-style: italic;
  background: var(--lp-gold-grad);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.landing-word {
  display: inline-block;
  transition: opacity .35s ease, filter .35s ease;
}
.landing-word--fade { opacity: 0; filter: blur(8px); }
.landing-sub {
  color: var(--lp-muted);
  font-size: clamp(.95rem, 2vw, 1.1rem);
  line-height: 1.7;
  max-width: 520px;
  margin: 0 auto 2rem;
}
.landing-cta-row {
  display: flex;
  gap: .85rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}
.glass-btn {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .9rem 1.75rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: .92rem;
  letter-spacing: .02em;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.06);
  color: var(--lp-fg);
  cursor: pointer;
  transition: background .25s, border-color .25s, transform .15s;
  text-decoration: none;
}
.glass-btn:hover {
  background: rgba(255,255,255,.12);
  border-color: rgba(255,255,255,.22);
}
.glass-btn--gold {
  background: rgba(201,168,98,.2);
  border-color: rgba(201,168,98,.45);
  color: var(--gold-lt);
}
.glass-btn--gold:hover {
  background: rgba(201,168,98,.35);
  border-color: rgba(201,168,98,.65);
}
.glass-btn:active { transform: scale(.98); }

/* Dashboard mockup */
.landing-dashboard-wrap {
  perspective: 1200px;
  max-width: 900px;
  margin: 0 auto;
}
.landing-dashboard {
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.12);
  box-shadow: 0 32px 80px rgba(0,0,0,.55), 0 0 0 1px rgba(255,255,255,.04) inset;
  transform-style: preserve-3d;
  transition: transform .05s linear;
  background: #141518;
}
.landing-dashboard-bar {
  display: flex;
  align-items: center;
  gap: .45rem;
  padding: .75rem 1rem;
  background: rgba(255,255,255,.04);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.landing-dashboard-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
}
.landing-dashboard-body {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  min-height: 280px;
}
.landing-dash-sidebar {
  padding: 1.25rem;
  border-right: 1px solid rgba(255,255,255,.06);
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.landing-dash-nav-item {
  padding: .55rem .75rem;
  border-radius: 8px;
  font-size: .78rem;
  color: var(--lp-muted);
}
.landing-dash-nav-item.active {
  background: rgba(201,168,98,.15);
  color: var(--gold-lt);
  font-weight: 600;
}
.landing-dash-main { padding: 1.25rem; }
.landing-dash-title {
  font-family: var(--serif);
  font-size: 1rem;
  margin-bottom: 1rem;
  color: var(--lp-fg);
}
.landing-dash-stops {
  display: flex;
  flex-direction: column;
  gap: .45rem;
}
.landing-dash-stop {
  display: flex;
  align-items: center;
  gap: .65rem;
  padding: .55rem .7rem;
  border-radius: 10px;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.06);
  font-size: .75rem;
}
.landing-dash-stop-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.landing-dash-stop-name { flex: 1; color: var(--lp-fg); font-weight: 600; }
.landing-dash-stop-addr { color: var(--lp-muted); font-size: .68rem; }

/* Trust strip */
.landing-trust {
  padding: 2.5rem 0;
  border-top: 1px solid rgba(255,255,255,.06);
  border-bottom: 1px solid rgba(255,255,255,.06);
  overflow: hidden;
}
.landing-trust-label {
  text-align: center;
  font-size: .72rem;
  text-transform: uppercase;
  letter-spacing: .18em;
  color: var(--lp-muted);
  margin-bottom: 1.5rem;
}
.landing-marquee {
  display: flex;
  width: max-content;
  animation: marquee 28s linear infinite;
}
.landing-marquee-content {
  display: flex;
  align-items: center;
}
.landing-marquee-item {
  padding: 0 2.5rem;
  font-family: var(--serif);
  font-size: 1.15rem;
  color: rgba(255,255,255,.35);
  white-space: nowrap;
  font-weight: 600;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* Sections */
.landing-section {
  padding: clamp(4rem, 8vw, 6rem) 1.25rem;
  max-width: 1120px;
  margin: 0 auto;
}
.landing-section-label {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .15em;
  color: var(--lp-muted);
  margin-bottom: 1rem;
}
.landing-section-label-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--gold);
}
.landing-section-title {
  font-family: var(--serif);
  font-size: clamp(1.9rem, 4vw, 3rem);
  font-weight: 500;
  line-height: 1.12;
  margin-bottom: 1rem;
  text-align: center;
}
.landing-section-sub {
  color: var(--lp-muted);
  font-size: .95rem;
  line-height: 1.65;
  text-align: center;
  max-width: 560px;
  margin: 0 auto 3rem;
}
.landing-gradient-text {
  background: var(--lp-gold-grad);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Metrics */
.landing-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}
.landing-metric {
  padding: 2rem 1.5rem;
  text-align: center;
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.landing-metric:nth-child(odd) { border-right: 1px solid rgba(255,255,255,.08); }
.landing-metric-label {
  font-size: .65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .14em;
  color: var(--lp-muted);
  margin-bottom: .75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .4rem;
}
.landing-metric-value {
  font-family: var(--serif);
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 500;
  line-height: 1;
  color: var(--lp-fg);
}
.landing-metric-desc {
  font-size: .78rem;
  color: var(--lp-muted);
  margin-top: .5rem;
}

/* Features */
.landing-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}
.landing-feature-list {
  display: flex;
  flex-direction: column;
  gap: .65rem;
}
.landing-feature-btn {
  width: 100%;
  text-align: left;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  padding: 1.1rem 1.2rem;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.08);
  background: transparent;
  color: var(--lp-fg);
  cursor: pointer;
  transition: border-color .25s, background .25s;
  position: relative;
  overflow: hidden;
}
.landing-feature-btn:hover { border-color: rgba(255,255,255,.16); }
.landing-feature-btn.active {
  border-color: rgba(201,168,98,.4);
  background: rgba(201,168,98,.06);
}
.landing-feature-icon {
  font-size: 1.4rem;
  flex-shrink: 0;
  margin-top: .1rem;
}
.landing-feature-title {
  font-weight: 700;
  font-size: .95rem;
  margin-bottom: .25rem;
}
.landing-feature-desc {
  font-size: .85rem;
  color: var(--lp-muted);
  line-height: 1.5;
}
.landing-feature-progress {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: rgba(255,255,255,.08);
}
.landing-feature-progress-bar {
  height: 100%;
  background: var(--gold);
  animation: feature-progress 6s linear forwards;
}
@keyframes feature-progress {
  from { width: 0%; }
  to { width: 100%; }
}
.landing-feature-preview {
  position: relative;
  min-height: 420px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  background: linear-gradient(145deg, #1a1b1f, #0f1012);
}
.landing-feature-card {
  position: absolute;
  inset: 0;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  transition: opacity .4s ease, transform .5s ease;
}
.landing-feature-card-inner {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 16px;
  padding: 1.75rem;
}
.landing-feature-card h3 {
  font-family: var(--serif);
  font-size: 1.5rem;
  margin-bottom: .75rem;
}
.landing-feature-card p {
  color: var(--lp-muted);
  font-size: .9rem;
  line-height: 1.6;
}

/* Roles grid */
.landing-roles {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.landing-role-card {
  padding: 1.5rem 1.25rem;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.02);
  transition: border-color .25s, transform .2s;
}
.landing-role-card:hover {
  border-color: rgba(201,168,98,.3);
  transform: translateY(-2px);
}
.landing-role-icon { font-size: 1.75rem; margin-bottom: .75rem; }
.landing-role-title {
  font-family: var(--serif);
  font-size: 1.05rem;
  margin-bottom: .4rem;
}
.landing-role-desc {
  font-size: .82rem;
  color: var(--lp-muted);
  line-height: 1.55;
}

/* FAQ */
.landing-faq-list {
  max-width: 720px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: .65rem;
}
.landing-faq-item {
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px;
  overflow: hidden;
  transition: border-color .25s;
}
.landing-faq-item:hover,
.landing-faq-item.open { border-color: rgba(255,255,255,.16); }
.landing-faq-q {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  padding: 1.15rem 1.35rem;
  background: none;
  border: none;
  color: var(--lp-fg);
  font-weight: 600;
  font-size: .95rem;
  text-align: left;
  cursor: pointer;
}
.landing-faq-chevron {
  flex-shrink: 0;
  color: var(--lp-muted);
  transition: transform .3s;
}
.landing-faq-item.open .landing-faq-chevron { transform: rotate(180deg); }
.landing-faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height .35s ease, opacity .35s ease;
  opacity: 0;
}
.landing-faq-item.open .landing-faq-a {
  max-height: 300px;
  opacity: 1;
}
.landing-faq-a p {
  padding: 0 1.35rem 1.15rem;
  color: var(--lp-muted);
  font-size: .9rem;
  line-height: 1.65;
}

/* CTA */
.landing-cta-section {
  position: relative;
  padding: clamp(5rem, 10vw, 8rem) 1.25rem;
  text-align: center;
  overflow: hidden;
}
.landing-cta-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: .35;
}
.landing-cta-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, var(--lp-bg), rgba(11,12,15,.7), var(--lp-bg));
}
.landing-cta-inner {
  position: relative;
  z-index: 2;
  max-width: 640px;
  margin: 0 auto;
}
.landing-cta-pill {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .45rem 1rem;
  border-radius: 999px;
  font-size: .78rem;
  color: var(--lp-muted);
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.04);
  margin-bottom: 1.5rem;
}

/* Footer */
.landing-footer {
  border-top: 1px solid rgba(255,255,255,.06);
  padding: 3rem 1.25rem 2rem;
  max-width: 1120px;
  margin: 0 auto;
}
.landing-footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 2rem;
  margin-bottom: 2.5rem;
}
.landing-footer-brand {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: .6rem;
}
.landing-footer-brand span { color: var(--gold-lt); }
.landing-footer-tagline {
  font-size: .82rem;
  color: var(--lp-muted);
  line-height: 1.6;
  max-width: 260px;
}
.landing-footer-col h4 {
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--lp-fg);
  margin-bottom: 1rem;
  font-family: var(--sans);
  font-weight: 700;
}
.landing-footer-col a {
  display: block;
  font-size: .85rem;
  color: var(--lp-muted);
  margin-bottom: .55rem;
  transition: color .2s;
}
.landing-footer-col a:hover { color: var(--lp-fg); }
.landing-footer-bottom {
  border-top: 1px solid rgba(255,255,255,.06);
  padding-top: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: .78rem;
  color: var(--lp-muted);
}
.landing-footer-links { display: flex; gap: 1.5rem; }
.landing-footer-links a:hover { color: var(--lp-fg); }

/* Scroll animations */
.stagger-reveal {
  opacity: 0;
  transform: translateY(20px);
  animation: stagger-in .8s cubic-bezier(.16,1,.3,1) forwards;
}
@keyframes stagger-in {
  to { opacity: 1; transform: translateY(0); }
}
.animate-on-scroll {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);
}
.animate-on-scroll.animate-in {
  opacity: 1;
  transform: translateY(0);
}

/* Marketing sub-pages dark shell */
.marketing-dark {
  position: relative;
  min-height: 100vh;
  background: var(--lp-bg);
  color: var(--lp-fg);
  overflow-x: hidden;
}
.marketing-dark::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse 70% 55% at 12% 88%, rgba(201,168,98,.12), transparent 60%),
    radial-gradient(ellipse 45% 38% at 88% 12%, rgba(201,168,98,.07), transparent 55%);
  pointer-events: none;
}
.marketing-dark::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  background-image: radial-gradient(rgba(255,255,255,.035) 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: .55;
  pointer-events: none;
}
.marketing-dark > main { position: relative; z-index: 1; }
.marketing-dark .card,
.marketing-dark .mkt-glass-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 16px;
  color: var(--lp-fg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.marketing-dark .title-pill {
  background: rgba(201,168,98,.2);
  border: 1px solid rgba(201,168,98,.35);
  color: var(--gold-lt);
}
.marketing-dark main p,
.marketing-dark .card p,
.marketing-dark .mkt-glass-card p { color: var(--lp-muted); }
.marketing-dark h1,
.marketing-dark h2,
.marketing-dark h3,
.marketing-dark h4 { color: var(--lp-fg); }
.marketing-dark .btn-outline {
  border-color: rgba(255,255,255,.18);
  color: var(--lp-fg);
}
.marketing-dark .btn-outline:hover {
  background: rgba(255,255,255,.06);
  opacity: 1;
}
.marketing-dark .btn-dark {
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.14);
  color: var(--lp-fg);
}

@media (max-width: 900px) {
  .landing-features { grid-template-columns: 1fr; }
  .landing-feature-preview { min-height: 280px; order: -1; }
  .landing-roles { grid-template-columns: repeat(2, 1fr); }
  .landing-footer-grid { grid-template-columns: 1fr 1fr; }
  .landing-dashboard-body { grid-template-columns: 1fr; }
  .landing-dash-sidebar { display: none; }
}

@media (min-width: 769px) {
  .site-nav-dropdown { display: none !important; }
}

@media (max-width: 768px) {
  .site-nav { top: .6rem; left: .6rem; right: .6rem; border-radius: 14px; }
  .site-nav-inner { height: 50px; padding: 0 .85rem; }
  .site-nav-brand { font-size: 1.15rem; }
  .site-nav-menu-btn { display: flex; }
  .landing-hero { padding: 5.5rem .85rem 2rem; min-height: auto; }
  .landing-headline { font-size: clamp(2rem, 9vw, 2.75rem); }
  .landing-sub { font-size: .92rem; margin-bottom: 1.5rem; }
  .landing-cta-row { flex-direction: column; align-items: stretch; }
  .landing-cta-row .glass-btn { justify-content: center; width: 100%; }
  .landing-dashboard { border-radius: 14px; }
  .landing-dashboard-wrap { margin-top: .5rem; }
  .landing-metrics { grid-template-columns: 1fr; }
  .landing-metric:nth-child(odd) { border-right: none; }
  .landing-roles { grid-template-columns: 1fr; }
  .landing-footer-grid { grid-template-columns: 1fr; }
  .landing-section { padding: 3rem .85rem; }
  .landing-footer-bottom { flex-direction: column; align-items: flex-start; }
}

/* ─── App shell (non-landing pages) ──────────────────── */
.app-shell {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 100% 60% at 50% -12%, rgba(195,162,86,.16), transparent 50%),
    radial-gradient(ellipse 50% 40% at 100% 20%, rgba(34,21,8,.05), transparent),
    linear-gradient(180deg, #FAF6EE 0%, var(--bg) 120px);
}
.app-main {
  max-width: 1040px;
  margin: 0 auto;
  padding: clamp(1.5rem, 4vw, 2.75rem) clamp(1rem, 4vw, 2rem) 3rem;
}
.app-card {
  background: #fff;
  border: 1px solid rgba(208,188,152,.55);
  border-radius: var(--r4);
  padding: 1.2rem 1.3rem;
  box-shadow: 0 1px 2px rgba(34,21,8,.04), 0 8px 24px rgba(34,21,8,.06);
}
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 1.75rem;
  flex-wrap: wrap;
  gap: 1rem;
}
.page-header h1 {
  font-size: clamp(1.65rem, 4vw, 2.25rem);
  margin-bottom: .25rem;
  letter-spacing: -.02em;
}
.page-header p { color: var(--t3); font-size: .92rem; }
.pill-tabs {
  display: inline-flex;
  gap: .3rem;
  margin-bottom: 1.75rem;
  flex-wrap: wrap;
  background: rgba(255,255,255,.65);
  border: 1px solid var(--border-lt);
  border-radius: var(--r3);
  padding: .28rem;
  box-shadow: var(--sh1);
}
.pill-tabs button {
  padding: .5rem 1.15rem;
  border-radius: calc(var(--r3) - 4px);
  border: none;
  cursor: pointer;
  font-size: .86rem;
  font-weight: 700;
  transition: background .15s, color .15s, box-shadow .15s;
  background: transparent;
  color: var(--t3);
  font-family: var(--sans);
}
.pill-tabs button.active {
  background: var(--dark);
  color: #fff;
  box-shadow: 0 2px 8px rgba(34,21,8,.15);
}
.admin-topbar {
  background: linear-gradient(135deg, #1a1006 0%, var(--dark) 55%, #2d1c0c 100%);
  padding: 0 clamp(1rem, 4vw, 2.5rem);
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  gap: 1rem;
  border-bottom: 1px solid rgba(195,162,86,.15);
  box-shadow: 0 4px 24px rgba(34,21,8,.12);
  position: sticky;
  top: 0;
  z-index: 100;
}
.admin-topbar-brand {
  font-family: var(--serif);
  font-size: 1.2rem;
  color: var(--t-cream);
  font-weight: 700;
  text-decoration: none;
  letter-spacing: -.01em;
}
.admin-topbar-brand span { color: var(--gold-lt); }
.admin-topbar-start {
  display: flex;
  align-items: center;
  gap: .85rem;
  min-width: 0;
}
.admin-topbar-back {
  color: rgba(255,255,255,.5);
  font-size: .84rem;
  text-decoration: none;
  flex-shrink: 0;
  transition: color .15s;
}
.admin-topbar-back:hover { color: rgba(255,255,255,.85); }
.admin-topbar-divider { color: rgba(255,255,255,.2); flex-shrink: 0; }
.admin-topbar-title {
  color: var(--t-cream);
  font-family: var(--serif);
  font-size: 1rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.admin-topbar-end {
  display: flex;
  gap: .65rem;
  align-items: center;
  flex-shrink: 0;
}
.admin-topbar-email {
  color: rgba(255,255,255,.42);
  font-size: .8rem;
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.admin-topbar-logout {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: var(--r1);
  padding: .38rem .8rem;
  color: rgba(255,255,255,.75);
  font-size: .78rem;
  font-weight: 600;
  cursor: pointer;
  font-family: var(--sans);
  transition: background .15s, border-color .15s;
}
.admin-topbar-logout:hover {
  background: rgba(255,255,255,.1);
  border-color: rgba(255,255,255,.22);
}
.admin-tabbar-wrap {
  padding: .85rem clamp(1rem, 4vw, 2.5rem) 0;
  background: transparent;
}
.admin-tabbar {
  display: flex;
  gap: .25rem;
  overflow-x: auto;
  scrollbar-width: none;
  background: rgba(255,255,255,.72);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(208,188,152,.45);
  border-radius: var(--r3);
  padding: .3rem;
  box-shadow: var(--sh1);
}
.admin-tabbar::-webkit-scrollbar { display: none; }
.admin-tabbar button {
  padding: .55rem 1.05rem;
  border: none;
  border-radius: calc(var(--r3) - 5px);
  background: transparent;
  font-weight: 600;
  color: var(--t3);
  cursor: pointer;
  font-size: .86rem;
  white-space: nowrap;
  font-family: var(--sans);
  transition: background .15s, color .15s, box-shadow .15s;
}
.admin-tabbar button:hover { color: var(--t1); }
.admin-tabbar button.active {
  font-weight: 700;
  color: var(--dark);
  background: #fff;
  box-shadow: 0 1px 4px rgba(34,21,8,.08);
}
.admin-section {
  margin-bottom: 1.75rem;
}
.admin-section-title {
  font-family: var(--serif);
  font-size: 1.05rem;
  margin-bottom: 1rem;
  padding-bottom: .55rem;
  border-bottom: 1px solid var(--border-lt);
  letter-spacing: -.01em;
}
.admin-section-hint {
  font-size: .78rem;
  color: var(--t3);
  margin: -.65rem 0 1rem;
  line-height: 1.5;
}
.admin-detail-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 2rem;
  align-items: start;
}
.admin-sidebar-card {
  background: #fff;
  border: 1px solid rgba(208,188,152,.55);
  border-radius: var(--r3);
  padding: 1.2rem;
  box-shadow: 0 1px 2px rgba(34,21,8,.04), 0 8px 24px rgba(34,21,8,.06);
  position: sticky;
  top: 5.5rem;
}
.admin-list {
  display: flex;
  flex-direction: column;
  gap: .65rem;
}
.admin-list-item {
  background: #fff;
  border: 1px solid rgba(208,188,152,.4);
  border-radius: var(--r3);
  padding: 1rem 1.2rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: 0 1px 3px rgba(34,21,8,.04);
  transition: border-color .15s, box-shadow .15s, transform .15s;
}
.admin-list-item:hover {
  border-color: rgba(195,162,86,.45);
  box-shadow: 0 4px 16px rgba(34,21,8,.07);
}
.admin-list-item--clickable {
  cursor: pointer;
  text-align: left;
  width: 100%;
  font-family: var(--sans);
}
.admin-stat-row {
  display: flex;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.admin-stat-card {
  background: #fff;
  border: 1px solid rgba(208,188,152,.4);
  border-radius: var(--r3);
  padding: .9rem 1.25rem;
  box-shadow: 0 1px 3px rgba(34,21,8,.04);
  min-width: 110px;
}
.admin-stat-card strong {
  display: block;
  font-size: 1.35rem;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -.02em;
}
.admin-stat-card span {
  font-size: .74rem;
  color: var(--t3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.admin-badge {
  font-size: .7rem;
  font-weight: 700;
  padding: .28rem .65rem;
  border-radius: var(--rpill);
  white-space: nowrap;
  letter-spacing: .02em;
}
.admin-badge--live {
  background: #ecfdf5;
  color: #047857;
  border: 1px solid #a7f3d0;
}
.admin-badge--paused {
  background: #f4f4f5;
  color: #71717a;
  border: 1px solid #e4e4e7;
}
.admin-badge--topbar-live {
  background: rgba(16,185,129,.15);
  color: #6ee7b7;
  border: 1px solid rgba(16,185,129,.25);
}
.admin-badge--topbar-paused {
  background: rgba(255,255,255,.08);
  color: rgba(255,255,255,.5);
  border: 1px solid rgba(255,255,255,.1);
}
.admin-tabbar-skeleton {
  background: #fff;
  border-bottom: 2px solid var(--border-lt);
  display: flex;
  gap: 1.5rem;
  overflow-x: auto;
  padding: 1.1rem clamp(1rem, 4vw, 2.5rem);
}
.fundraiser-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid rgba(208,188,152,.45);
  box-shadow: 0 1px 2px rgba(34,21,8,.04), 0 10px 28px rgba(34,21,8,.07);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .2s, box-shadow .2s;
}
.fundraiser-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(34,21,8,.06), 0 16px 40px rgba(34,21,8,.1);
}
.fundraiser-card-body { padding: 1.4rem 1.5rem; flex: 1; }
.fundraiser-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: .75rem;
}
.fundraiser-card-header h2 {
  font-family: var(--serif);
  font-size: 1.15rem;
  line-height: 1.25;
  letter-spacing: -.01em;
}
.fundraiser-card-stats {
  display: flex;
  gap: 1.35rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}
.fundraiser-card-stat strong {
  display: block;
  font-size: 1.15rem;
  font-weight: 800;
}
.fundraiser-card-stat span {
  font-size: .7rem;
  color: var(--t3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
}
.fundraiser-card-checklist {
  background: var(--surface);
  border-radius: var(--r2);
  padding: .85rem;
  margin-bottom: 1rem;
}
.fundraiser-card-check {
  display: flex;
  align-items: flex-start;
  gap: .5rem;
  font-size: .8rem;
  padding: .18rem 0;
}
.fundraiser-card-check::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: .38rem;
}
.fundraiser-card-check--ok::before { background: #059669; }
.fundraiser-card-check--no::before { background: #d97706; }
.fundraiser-card-check--ok { color: #047857; }
.fundraiser-card-check--no { color: #b45309; }
.fundraiser-card-linkbox {
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: var(--r2);
  padding: .7rem .9rem;
  margin-bottom: 1rem;
}
.fundraiser-card-linkbox p {
  font-size: .68rem;
  font-weight: 700;
  color: #92400e;
  margin-bottom: .2rem;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.fundraiser-card-linkbox a {
  font-size: .78rem;
