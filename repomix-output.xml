}
.modal-card {
  background: #fff;
  border-radius: 16px;
  padding: 2rem;
  width: 100%;
  max-width: 440px;
  box-shadow: var(--sh3);
}
.error-banner {
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  color: #991b1b;
}

/* ─── Login page (landing-aligned) ─────────────────────── */
.login-page {
  position: relative;
  min-height: 100vh;
}
.login-page-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse 70% 55% at 15% 85%, rgba(201,168,98,.14), transparent 60%),
    radial-gradient(ellipse 50% 40% at 85% 15%, rgba(201,168,98,.08), transparent 55%),
    var(--lp-bg);
  pointer-events: none;
}
.login-page-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,.035) 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: .6;
}
.login-page-glow {
  position: fixed;
  top: 20%;
  right: 10%;
  width: min(480px, 50vw);
  height: min(480px, 50vw);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201,168,98,.12) 0%, transparent 70%);
  filter: blur(40px);
  z-index: 0;
  pointer-events: none;
}
.login-page-main {
  position: relative;
  z-index: 1;
  max-width: 1180px;
  margin: 0 auto;
  padding: clamp(6.5rem, 14vw, 8rem) clamp(1.25rem, 4vw, 2rem) clamp(3rem, 8vw, 5rem);
}
.login-page-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2.5rem, 5vw, 4.5rem);
  align-items: start;
}
.login-page-hero {
  padding-top: clamp(0rem, 2vw, 2rem);
}
.login-headline {
  font-size: clamp(2.4rem, 5vw, 3.5rem);
  text-align: left;
  margin-bottom: 1rem;
}
.login-sub {
  text-align: left;
  margin: 0 0 2.25rem;
  max-width: 440px;
}
.login-role-grid {
  display: flex;
  flex-direction: column;
  gap: .75rem;
}
.login-role-card {
  display: flex;
  align-items: flex-start;
  gap: .9rem;
  padding: 1rem 1.1rem;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: border-color .2s, background .2s;
}
.login-role-card:hover {
  border-color: rgba(201,168,98,.25);
  background: rgba(255,255,255,.05);
}
.login-role-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: rgba(201,168,98,.12);
  border: 1px solid rgba(201,168,98,.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.05rem;
  flex-shrink: 0;
}
.login-role-card strong {
  display: block;
  font-size: .92rem;
  font-weight: 700;
  color: var(--lp-fg);
  margin-bottom: .2rem;
}
.login-role-card p {
  font-size: .82rem;
  color: var(--lp-muted);
  line-height: 1.5;
  margin: 0;
}
.login-panel {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
  max-width: 440px;
  justify-self: end;
}
.login-glass-card {
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(20,21,24,.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 24px 64px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.04) inset;
  padding: 1.75rem 1.65rem;
}
.login-card-header h2 {
  font-family: var(--serif);
  font-size: 1.5rem;
  font-weight: 500;
  letter-spacing: -.01em;
  margin-bottom: .35rem;
  color: var(--lp-fg);
}
.login-card-header p {
  font-size: .86rem;
  color: var(--lp-muted);
  margin-bottom: 1.35rem;
  line-height: 1.5;
}
.login-tab-switch {
  display: flex;
  gap: .35rem;
  padding: .3rem;
  border-radius: 12px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  margin-bottom: 1.25rem;
}
.login-tab-switch button {
  flex: 1;
  padding: .6rem .75rem;
  border: none;
  border-radius: 9px;
  font-family: var(--sans);
  font-size: .84rem;
  font-weight: 600;
  color: var(--lp-muted);
  background: transparent;
  cursor: pointer;
  transition: background .2s, color .2s;
}
.login-tab-switch button:hover { color: var(--lp-fg); }
.login-tab-switch button.active {
  background: rgba(201,168,98,.22);
  color: var(--gold-lt);
  box-shadow: 0 1px 4px rgba(0,0,0,.2);
}
.login-alert {
  background: rgba(191,53,53,.12);
  border: 1px solid rgba(239,68,68,.3);
  border-radius: 12px;
  padding: .75rem .9rem;
  color: #fca5a5;
  font-size: .86rem;
  line-height: 1.45;
  margin-bottom: 1rem;
}
.login-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.login-field {
  display: flex;
  flex-direction: column;
  gap: .4rem;
}
.login-field span {
  font-size: .7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--lp-muted);
}
.login-field input {
  width: 100%;
  padding: .8rem 1rem;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.05);
  color: var(--lp-fg);
  font-family: var(--sans);
  font-size: .95rem;
  outline: none;
  transition: border-color .2s, box-shadow .2s, background .2s;
}
.login-field input::placeholder { color: rgba(167,171,179,.55); }
.login-field input:focus {
  border-color: rgba(201,168,98,.5);
  background: rgba(255,255,255,.07);
  box-shadow: 0 0 0 3px rgba(201,168,98,.15);
}
.login-field input:-webkit-autofill,
.login-field input:-webkit-autofill:hover,
.login-field input:-webkit-autofill:focus {
  -webkit-box-shadow: 0 0 0 1000px #1a1b1f inset !important;
  -webkit-text-fill-color: var(--lp-fg) !important;
  caret-color: var(--lp-fg);
  border-color: rgba(201,168,98,.35);
}
.login-forgot-row {
  text-align: right;
  margin-top: -.25rem;
}
.login-forgot-row a {
  font-size: .82rem;
  color: var(--lp-muted);
  transition: color .15s;
}
.login-forgot-row a:hover { color: var(--gold-lt); }
.login-submit {
  width: 100%;
  justify-content: center;
  margin-top: .25rem;
  border: none;
}
.login-divider {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin: .25rem 0;
}
.login-divider::before,
.login-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,.1);
}
.login-divider span {
  font-size: .78rem;
  color: var(--lp-muted);
  text-transform: uppercase;
  letter-spacing: .08em;
}
.login-google-btn {
  width: 100%;
  justify-content: center;
  border: none;
}
.login-driver-card {
  padding: 1.35rem 1.5rem;
}
.login-driver-title {
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--gold-lt);
  margin-bottom: .35rem;
}
.login-driver-desc {
  font-size: .84rem;
  color: var(--lp-muted);
  margin-bottom: 1rem;
  line-height: 1.45;
}
.login-otp-row {
  display: flex;
  gap: .45rem;
  justify-content: center;
  margin-bottom: 1rem;
}
.login-otp-cell {
  width: 44px;
  height: 52px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.05);
  text-align: center;
  font-size: 1.15rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--lp-fg);
  outline: none;
  font-family: var(--sans);
  transition: border-color .15s, box-shadow .15s, background .15s;
}
.login-otp-cell:focus {
  border-color: rgba(201,168,98,.55);
  background: rgba(255,255,255,.08);
  box-shadow: 0 0 0 3px rgba(201,168,98,.15);
}
.login-driver-btn {
  width: 100%;
  justify-content: center;
  border: none;
}
.login-footer {
  text-align: center;
  font-size: .84rem;
  color: var(--lp-muted);
}
.login-footer a {
  color: var(--gold-lt);
  font-weight: 600;
  transition: color .15s;
}
.login-footer a:hover { color: #e8d4a8; }

@media (max-width: 900px) {
  .login-page-grid {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .login-panel {
    max-width: none;
    justify-self: stretch;
  }
  .login-headline,
  .login-sub { text-align: center; }
  .login-sub { margin-left: auto; margin-right: auto; }
  .login-page-hero .landing-eyebrow { justify-content: center; width: 100%; }
}
@media (max-width: 480px) {
  .login-otp-cell {
    width: 40px;
    height: 48px;
    font-size: 1rem;
  }
  .login-otp-row { gap: .35rem; }
  .login-glass-card { padding: 1.4rem 1.2rem; }
}

/* ─── Marketing sub-pages ──────────────────────────────── */
.marketing-page-main {
  max-width: 920px;
  margin: 0 auto;
  padding: clamp(6rem, 13vw, 7.5rem) clamp(1.25rem, 4vw, 2rem) 5rem;
}
.marketing-page-main--narrow { max-width: 560px; text-align: center; }
.marketing-page-hero {
  text-align: center;
  margin-bottom: 2.75rem;
}
.marketing-page-hero--left { text-align: left; }
.marketing-page-hero--left p { margin-left: 0; margin-right: 0; }
.marketing-page-hero h1 {
  font-family: var(--serif);
  font-size: clamp(2rem, 4.5vw, 3rem);
  font-weight: 500;
  line-height: 1.12;
  letter-spacing: -.02em;
  margin-bottom: .85rem;
}
.marketing-page-hero p {
  color: var(--lp-muted);
  line-height: 1.7;
  font-size: .97rem;
