/* ─── Skeleton loaders ─────────────────────────────────── */
@keyframes skeleton-shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.skeleton {
  background: linear-gradient(
    90deg,
    var(--surface-2) 0%,
    var(--surface-3) 40%,
    var(--surface-2) 80%
  );
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
  border-radius: var(--r2);
}
.skeleton--circle { border-radius: 50%; }
.skeleton--rounded { border-radius: var(--r3); }
.skeleton--line { height: .85rem; margin-bottom: .5rem; }
.skeleton--sm { height: .65rem; }
.skeleton--dark {
  background: linear-gradient(
    90deg,
    rgba(255,255,255,.06) 0%,
    rgba(255,255,255,.14) 40%,
    rgba(255,255,255,.06) 80%
  );
  background-size: 200% 100%;
}
.skeleton-text-block { margin-bottom: 1rem; }
.skeleton-list { display: flex; flex-direction: column; gap: .75rem; }
.skeleton-list-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.25rem;
}
.skeleton-dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  gap: 1rem;
}
.skeleton-pill-row { display: flex; gap: .4rem; flex-wrap: wrap; }
.skeleton-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.25rem;
}
.skeleton-fundraiser-card { padding: 1.5rem; }
.skeleton-stat-row {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}
.skeleton-product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
}
.skeleton-product-card { overflow: hidden; }
.skeleton-driver { max-width: 640px; margin: 0 auto; }
.skeleton-driver-center {
  min-height: 100vh;
  background: var(--dark);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 2rem;
}

/* ─── Driver portal ────────────────────────────────────── */
.driver-portal {
  min-height: 100vh;
  background: var(--dark);
  display: flex;
