          </p>
        </div>

        <div className="landing-features">
          <div className="landing-feature-list">
            {FEATURES.map((f, i) => (
              <button
                key={i}
                type="button"
                className={`landing-feature-btn ${featureIdx === i ? 'active' : ''}`}
                onClick={() => {
                  setFeatureFade(false);
                  setTimeout(() => { setFeatureIdx(i); setFeatureFade(true); }, 200);
                }}
              >
