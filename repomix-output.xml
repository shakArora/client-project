  margin-bottom: .3rem;
}
.mkt-stat-label {
  font-size: .74rem;
  color: var(--lp-muted);
  line-height: 1.4;
}
.mkt-feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: .85rem;
  margin-bottom: 2.5rem;
}
.mkt-feature-card { padding: 1.25rem 1.3rem; }
.mkt-feature-icon { font-size: 1.75rem; margin-bottom: .55rem; }
.mkt-feature-card h3 {
  font-family: var(--serif);
  font-size: 1.05rem;
  margin-bottom: .45rem;
}
.mkt-story-card { padding: 1.75rem; margin-bottom: 2rem; }
.mkt-story-card h2 {
  font-family: var(--serif);
  font-size: 1.45rem;
  margin-bottom: .75rem;
}
.mkt-timeline { margin-bottom: 2.5rem; }
.mkt-timeline-step {
  display: flex;
  gap: 1.1rem;
  margin-bottom: 1.1rem;
}
.mkt-timeline-step:last-child { margin-bottom: 0; }
.mkt-timeline-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.mkt-timeline-num {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(201,168,98,.25);
  border: 1px solid rgba(201,168,98,.45);
  color: var(--gold-lt);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: .9rem;
  flex-shrink: 0;
}
.mkt-timeline-line {
  width: 2px;
  flex: 1;
  background: rgba(255,255,255,.1);
  margin-top: 4px;
  min-height: 12px;
}
.mkt-timeline-body { padding-bottom: .25rem; }
.mkt-timeline-body strong {
  display: block;
  font-size: .95rem;
  margin-bottom: .2rem;
}
.mkt-callout {
  padding: 1.35rem 1.4rem;
  margin-bottom: 2rem;
  border-radius: 16px;
}
.mkt-callout--green {
  background: rgba(34,197,94,.08);
  border: 1px solid rgba(34,197,94,.22);
}
.mkt-callout h3 {
  font-family: var(--serif);
  font-size: 1.1rem;
