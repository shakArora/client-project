<file path="src/App.css">
.site {
  width: min(1120px, 92vw);
  margin: 0 auto;
  padding: 1.2rem 0 2.5rem;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.9rem 1.1rem;
  border-radius: 0.95rem;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(56, 122, 168, 0.18);
  position: sticky;
  top: 0.85rem;
  z-index: 10;
}

.brand {
  text-decoration: none;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: #0a2f4a;
}

.nav-links {
  display: flex;
  gap: 1.2rem;
}

.nav-links a {
  text-decoration: none;
  color: #2d5673;
  font-weight: 600;
}

.nav-links a:hover {
  color: #154465;
}

.nav-cta {
  border: 0;
  border-radius: 0.7rem;
  padding: 0.6rem 0.95rem;
  font-family: inherit;
  font-weight: 700;
  background: linear-gradient(135deg, #ff5a5f, #ff7a67);
  color: #fff;
}

.hero {
  margin-top: 2rem;
  background: linear-gradient(165deg, #0f4d73 0%, #1f7ab0 58%, #49a8d8 100%);
  border-radius: 1.25rem;
  padding: clamp(1.5rem, 4vw, 3rem);
  color: #f7fbff;
  box-shadow: 0 20px 50px rgba(15, 77, 115, 0.25);
}

.eyebrow {
  margin: 0;
  color: #bde9ff;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 700;
  font-size: 0.75rem;
}

.hero h1 {
  margin: 0.65rem 0 0.8rem;
  font-size: clamp(1.8rem, 4vw, 3.15rem);
  max-width: 15ch;
  line-height: 1.1;
}

.hero-text {
  margin: 0;
  max-width: 58ch;
  color: #e6f6ff;
}

.hero-actions {
  margin-top: 1.3rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.btn {
  border: 0;
  border-radius: 0.75rem;
  padding: 0.75rem 1rem;
  font-family: inherit;
  font-weight: 700;
  cursor: pointer;
}

.btn-primary {
  color: #fff;
  background: linear-gradient(135deg, #ff545d, #ff8d5a);
}

.btn-secondary {
  color: #e9f7ff;
  background: rgba(255, 255, 255, 0.16);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.metrics {
  margin-top: 1.4rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
}

.metrics article {
  background: rgba(255, 255, 255, 0.13);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 0.75rem;
  padding: 0.8rem;
  display: grid;
  gap: 0.2rem;
}

.metrics strong {
  font-size: 1.3rem;
  line-height: 1;
}

.metrics span {
  color: #d4f0ff;
  font-size: 0.87rem;
}

.features,
.steps {
  margin-top: 1.7rem;
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(76, 136, 173, 0.2);
  border-radius: 1.1rem;
  padding: clamp(1rem, 2.6vw, 1.8rem);
}

.features h2,
.steps h2 {
  margin: 0;
  color: #123b58;
  font-size: clamp(1.2rem, 2.4vw, 1.7rem);
}

.feature-grid {
  margin-top: 1rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.75rem;
}

.card {
  border-radius: 0.9rem;
  border: 1px solid #d6e9f4;
  background: #f8fdff;
  padding: 1rem;
}

.card h3 {
  margin: 0;
  font-size: 1.02rem;
  color: #164867;
}

.card p {
  margin: 0.55rem 0 0;
  color: #49667b;
  line-height: 1.45;
}

.step-grid {
  margin-top: 1rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.75rem;
}

.step-grid article {
  border-radius: 0.9rem;
  border: 1px solid #d6e9f4;
  background: #f7fcff;
  padding: 1rem;
}

.step-grid span {
  display: inline-flex;
  width: 2rem;
  height: 2rem;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #d9effb;
  color: #155275;
  font-weight: 700;
  font-size: 0.8rem;
}

.step-grid h3 {
  margin: 0.65rem 0 0.35rem;
  font-size: 1.02rem;
  color: #164867;
}

.step-grid p {
  margin: 0;
  color: #49667b;
}

.footer {
  margin-top: 1.6rem;
  border-radius: 1.1rem;
  padding: 1.2rem;
  background: #0e3550;
  color: #e7f6ff;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
}

.footer p {
  margin: 0;
  font-size: 1.05rem;
}

@media (max-width: 860px) {
  .nav-links {
    display: none;
  }

  .metrics,
  .feature-grid,
  .step-grid {
    grid-template-columns: 1fr;
  }

  .hero h1 {
    max-width: 100%;
  }

  .footer {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 480px) {
  .site {
    width: 94vw;
    padding-top: 0.8rem;
  }

  .top-nav {
    padding: 0.75rem;
  }

  .nav-cta {
    padding: 0.55rem 0.8rem;
    font-size: 0.85rem;
  }

  .hero {
    padding: 1.15rem;
  }

  .hero-actions {
    flex-direction: column;
  }

  .btn {
    width: 100%;
  }
}
</file>

