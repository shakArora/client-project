}
.mkt-cta-row {
  display: flex;
  gap: .85rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: .5rem;
}
.mkt-role-section { margin-bottom: 2.5rem; }
.mkt-role-header {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1rem;
}
.mkt-role-badge {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  flex-shrink: 0;
}
.mkt-role-badge--admin {
  background: rgba(201,168,98,.15);
  border: 1px solid rgba(201,168,98,.3);
}
.mkt-role-badge--vendor {
  background: rgba(34,197,94,.12);
  border: 1px solid rgba(34,197,94,.28);
}
.mkt-role-badge--customer {
  background: rgba(245,158,11,.12);
  border: 1px solid rgba(245,158,11,.28);
}
.mkt-role-badge--driver {
  background: rgba(167,139,250,.12);
  border: 1px solid rgba(167,139,250,.28);
}
.mkt-role-title {
  font-family: var(--serif);
  font-size: 1.4rem;
}
.mkt-role-title--admin { color: var(--gold-lt); }
.mkt-role-title--vendor { color: #6ee7b7; }
.mkt-role-title--customer { color: #fcd34d; }
.mkt-role-title--driver { color: #c4b5fd; }
.mkt-step-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: .75rem;
}
.mkt-step-card {
  display: flex;
  gap: .75rem;
  padding: 1rem 1.1rem;
}
.mkt-step-num {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .78rem;
  font-weight: 800;
  flex-shrink: 0;
  color: #fff;
}
.mkt-step-num--admin { background: rgba(201,168,98,.85); }
.mkt-step-num--vendor { background: rgba(16,185,129,.85); }
.mkt-step-num--customer { background: rgba(245,158,11,.85); }
.mkt-step-num--driver { background: rgba(139,92,246,.85); }
.mkt-step-card strong {
  display: block;
  font-size: .93rem;
  margin-bottom: .25rem;
  color: var(--lp-fg);
}
.mkt-faq { display: flex; flex-direction: column; gap: .5rem; }
.mkt-faq-item {
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.1);
