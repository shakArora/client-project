          <>
            <h1 style={{ fontFamily: 'var(--serif)', fontSize: '2.1rem', marginBottom: '.45rem' }}>Reset Password</h1>
            <p style={{ color: 'var(--t3)', marginBottom: '2rem', lineHeight: 1.55 }}>
