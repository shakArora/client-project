# ── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # set to "production" on Railway

# ── MongoDB Atlas ──────────────────────────────────────
# URL-encode any special chars in password: # → %23  @ → %40  $ → %24
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/routed?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Google OAuth (admin login) ────────────────────────
GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_WHITELIST=admin@yourdomain.com,other@yourdomain.com

# ── CORS ──────────────────────────────────────────────
# In production set this to your Netlify URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP (optional) ───────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Routed <no-reply@routed.com>

# ── Twilio SMS (optional) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Password Reset ────────────────────────────────────
RESET_TOKEN_TTL_MINUTES=15
