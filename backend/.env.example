# ────────────────────────────────────────────────────────
#  Routed – Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Get this from MongoDB Atlas → Cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/routed?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
# Use a long random string — generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-48-chars
JWT_EXPIRES_IN=7d

# ── Google OAuth (admin login only) ─────────────────────
# Get from console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=replace-with-your-client-id.apps.googleusercontent.com
# Comma-separated list of Google email addresses allowed to log in as Admin
ADMIN_GOOGLE_WHITELIST=you@gmail.com,colleague@gmail.com

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Password Reset ────────────────────────────────────────
RESET_TOKEN_TTL_MINUTES=15

# ── Email (SMTP) — optional, for password reset emails ───
# Works with Gmail app passwords, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Routed <no-reply@routed.com>

# ── SMS via Twilio — optional, for password reset SMS ────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555555555
